---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  className?: string;
  [key: string]: any;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  className = '',
  ...rest
} = Astro.props;

const baseStyles = 'inline-flex items-center justify-center font-medium rounded-lg transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-brand-500/50 active:scale-[0.98] cursor-pointer';

const variants = {
  primary: 'bg-gradient-to-r from-brand-600 to-brand-500 text-white shadow-lg shadow-brand-950/30 hover:shadow-brand-700/20 hover:from-brand-500 hover:to-brand-400 border border-brand-500/10',
  secondary: 'bg-dark-800 hover:bg-dark-700 text-white border border-dark-700/50',
  outline: 'border border-dark-700 hover:border-brand-500 text-dark-200 hover:text-white hover:bg-brand-950/10',
  ghost: 'text-dark-300 hover:text-white hover:bg-dark-900/50',
};

const sizes = {
  sm: 'px-3.5 py-1.5 text-xs',
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-6 py-3 text-base',
};

const Element = href ? 'a' : 'button';
---

<Element
  href={href}
  class:list={[baseStyles, variants[variant], sizes[size], className]}
  {...rest}
>
  <slot />
</Element>
