---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline';
  className?: string;
}

const { variant = 'primary', className = '' } = Astro.props;

const baseStyles = 'inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium transition-all duration-300';

const variants = {
  primary: 'bg-brand-950/40 text-brand-300 border border-brand-800/40 hover:bg-brand-950/60',
  secondary: 'bg-dark-800 text-dark-200 border border-dark-700/50 hover:bg-dark-700/60',
  outline: 'text-dark-300 border border-dark-700 hover:border-dark-600',
};
---

<span class:list={[baseStyles, variants[variant], className]}>
  <slot />
</span>
