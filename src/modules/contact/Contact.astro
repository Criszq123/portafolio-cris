---
import Button from '@ui/Button.astro';
---

<section id="contact" class="py-24 relative overflow-hidden">
  <!-- Glowing blob in the background of contact -->
  <div class="absolute bottom-[-10%] right-[-10%] w-[350px] h-[350px] rounded-full bg-brand-900/10 blur-[90px] pointer-events-none"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      
      <!-- Left side info -->
      <div class="lg:col-span-5 space-y-6 text-left">
        <span class="text-xs font-bold uppercase tracking-wider text-brand-400 font-mono">
          Contacto
        </span>
        <h2 class="font-outfit text-3xl sm:text-4xl font-extrabold text-white">
          ¿Hablamos de tu próximo proyecto?
        </h2>
        <p class="text-sm sm:text-base text-dark-400 leading-relaxed font-sans">
          Ya sea que busques incorporar un desarrollador a tu equipo, lanzar un nuevo sitio web, o simplemente quieras charlar sobre tecnología, no dudes en escribirme.
        </p>
        
        <div class="space-y-4 pt-4">
          <div class="flex items-center gap-4 group">
            <div class="h-10 w-10 rounded-lg bg-dark-900 border border-dark-800 flex items-center justify-center text-brand-400 group-hover:border-brand-900/50 group-hover:bg-brand-950/20 transition-all duration-300">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <div class="text-[10px] uppercase font-mono text-dark-500">Email</div>
              <a href="mailto:cristofhermarquez88@gmail.com" class="text-sm font-medium text-dark-200 hover:text-brand-300 transition-colors">cristofhermarquez88@gmail.com</a>
            </div>
          </div>

          <div class="flex items-center gap-4 group">
            <div class="h-10 w-10 rounded-lg bg-dark-900 border border-dark-800 flex items-center justify-center text-brand-400 group-hover:border-brand-900/50 group-hover:bg-brand-950/20 transition-all duration-300">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25v-7.5A7.5 7.5 0 0019.5 10.5z" />
              </svg>
            </div>
            <div>
              <div class="text-[10px] uppercase font-mono text-dark-500">Ubicación</div>
              <div class="text-sm font-medium text-dark-200">Campeche, México · Remote-ready</div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Right side form -->
      <div class="lg:col-span-7 w-full relative">
        <div class="absolute -inset-1 rounded-2xl bg-gradient-to-tr from-brand-900 to-brand-500 opacity-10 blur-xl pointer-events-none"></div>
        <form class="relative w-full rounded-xl border border-dark-800 bg-dark-900/40 p-8 backdrop-blur-sm space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="space-y-1.5 text-left">
              <label for="name" class="text-xs font-semibold text-dark-300 uppercase tracking-wider font-mono">Nombre</label>
              <input type="text" id="name" name="name" required class="w-full rounded-lg border border-dark-800 bg-dark-950/50 px-4 py-3 text-sm text-white placeholder-dark-600 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500/30 transition-all duration-300" placeholder="Juan Pérez" />
            </div>
            <div class="space-y-1.5 text-left">
              <label for="email" class="text-xs font-semibold text-dark-300 uppercase tracking-wider font-mono">Correo Electrónico</label>
              <input type="email" id="email" name="email" required class="w-full rounded-lg border border-dark-800 bg-dark-950/50 px-4 py-3 text-sm text-white placeholder-dark-600 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500/30 transition-all duration-300" placeholder="juan@correo.com" />
            </div>
          </div>
          
          <div class="space-y-1.5 text-left">
            <label for="subject" class="text-xs font-semibold text-dark-300 uppercase tracking-wider font-mono">Asunto</label>
            <input type="text" id="subject" name="subject" required class="w-full rounded-lg border border-dark-800 bg-dark-950/50 px-4 py-3 text-sm text-white placeholder-dark-600 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500/30 transition-all duration-300" placeholder="Oportunidad laboral / Proyecto" />
          </div>

          <div class="space-y-1.5 text-left">
            <label for="message" class="text-xs font-semibold text-dark-300 uppercase tracking-wider font-mono">Mensaje</label>
            <textarea id="message" name="message" rows="5" required class="w-full rounded-lg border border-dark-800 bg-dark-950/50 px-4 py-3 text-sm text-white placeholder-dark-600 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500/30 transition-all duration-300 resize-none" placeholder="Hola, me gustaría platicar contigo sobre..."></textarea>
          </div>

          <Button type="submit" variant="primary" className="w-full py-3 justify-center">
            Enviar Mensaje
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
            </svg>
          </Button>
        </form>
      </div>
      
    </div>
  </div>
</section>
