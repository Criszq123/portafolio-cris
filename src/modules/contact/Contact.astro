---
import Button from '@ui/Button.astro';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="py-24 relative overflow-hidden">
  <!-- Glowing blob in the background of contact -->
  <div class="absolute bottom-[-10%] right-[-10%] w-[350px] h-[350px] rounded-full bg-brand-900/10 blur-[90px] pointer-events-none"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      
      <!-- Left side info -->
      <div class="lg:col-span-5 space-y-6 text-left">
        <span class="text-xs font-bold uppercase tracking-wider text-brand-400 font-mono">
          {t('contact.badge')}
        </span>
        <h2 class="font-outfit text-3xl sm:text-4xl font-extrabold text-white">
          {t('contact.title')}
        </h2>
        <p class="text-sm sm:text-base text-dark-400 leading-relaxed font-sans">
          {t('contact.subtitle')}
        </p>
        
        <div class="space-y-4 pt-4">
          <div class="flex items-center gap-4 group">
            <div class="h-10 w-10 rounded-lg bg-dark-900 border border-dark-800 flex items-center justify-center text-brand-400 group-hover:border-brand-900/50 group-hover:bg-brand-950/20 transition-all duration-300">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <div class="text-[10px] uppercase font-mono text-dark-500">Email</div>
              <a href="mailto:cristofhermarquez88@gmail.com" class="text-sm font-medium text-dark-200 hover:text-brand-300 transition-colors">cristofhermarquez88@gmail.com</a>
            </div>
          </div>

          <div class="flex items-center gap-4 group">
            <div class="h-10 w-10 rounded-lg bg-dark-900 border border-dark-800 flex items-center justify-center text-brand-400 group-hover:border-brand-900/50 group-hover:bg-brand-950/20 transition-all duration-300">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25v-7.5A7.5 7.5 0 0019.5 10.5z" />
              </svg>
            </div>
            <div>
              <div class="text-[10px] uppercase font-mono text-dark-500">{t('contact.location')}</div>
              <div class="text-sm font-medium text-dark-200">{t('contact.locationValue')}</div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Right side form -->
      <div class="lg:col-span-7 w-full relative">
        <div class="absolute -inset-1 rounded-2xl bg-gradient-to-tr from-brand-900 to-brand-500 opacity-10 blur-xl pointer-events-none"></div>
        <form id="contact-form" data-lang={lang} class="relative w-full rounded-xl border border-dark-800 bg-dark-900/40 p-8 backdrop-blur-sm space-y-6">
          <!-- Campo Honeypot (Trampa para spam) -->
          <div class="hidden" aria-hidden="true">
            <label for="honeypot">No rellenar este campo</label>
            <input type="text" id="honeypot" name="honeypot" tabindex="-1" autocomplete="off" />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="space-y-1.5 text-left">
              <label for="name" class="text-xs font-semibold text-dark-300 uppercase tracking-wider font-mono">{t('contact.labelName')}</label>
              <input type="text" id="name" name="name" autocomplete="name" required class="w-full rounded-lg border border-dark-800 bg-dark-950/50 px-4 py-3 text-sm text-white placeholder-dark-600 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500/30 transition-all duration-300" placeholder={t('contact.placeholderName')} />
            </div>
            <div class="space-y-1.5 text-left">
              <label for="email" class="text-xs font-semibold text-dark-300 uppercase tracking-wider font-mono">{t('contact.labelEmail')}</label>
              <input type="email" id="email" name="email" autocomplete="email" required class="w-full rounded-lg border border-dark-800 bg-dark-950/50 px-4 py-3 text-sm text-white placeholder-dark-600 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500/30 transition-all duration-300" placeholder={t('contact.placeholderEmail')} />
            </div>
          </div>
          
          <div class="space-y-1.5 text-left">
            <label for="subject" class="text-xs font-semibold text-dark-300 uppercase tracking-wider font-mono">{t('contact.labelSubject')}</label>
            <input type="text" id="subject" name="subject" required class="w-full rounded-lg border border-dark-800 bg-dark-950/50 px-4 py-3 text-sm text-white placeholder-dark-600 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500/30 transition-all duration-300" placeholder={t('contact.placeholderSubject')} />
          </div>

          <div class="space-y-1.5 text-left">
            <label for="message" class="text-xs font-semibold text-dark-300 uppercase tracking-wider font-mono">{t('contact.labelMessage')}</label>
            <textarea id="message" name="message" rows="5" required class="w-full rounded-lg border border-dark-800 bg-dark-950/50 px-4 py-3 text-sm text-white placeholder-dark-600 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500/30 transition-all duration-300 resize-none" placeholder={t('contact.placeholderMessage')}></textarea>
          </div>

          <Button type="submit" variant="primary" className="w-full py-3 justify-center" id="submit-btn">
            <span id="submit-text" class="flex items-center justify-center gap-2">
              {t('contact.submitBtn')}
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
              </svg>
            </span>
          </Button>
        </form>
      </div>
      
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitText = document.getElementById('submit-text') as HTMLSpanElement;

  const submittingTexts = {
    es: 'Enviando...',
    en: 'Sending...'
  };

  const toastMessages = {
    es: {
      success: '¡Mensaje enviado con éxito!',
      error: 'Hubo un error al enviar el mensaje.',
      errorFields: 'Todos los campos son obligatorios.',
      errorEmail: 'El formato del correo electrónico no es válido.',
      errorUnexpected: 'Ocurrió un error inesperado al enviar el mensaje.'
    },
    en: {
      success: 'Message sent successfully!',
      error: 'There was an error sending the message.',
      errorFields: 'All fields are required.',
      errorEmail: 'The email format is not valid.',
      errorUnexpected: 'An unexpected error occurred while sending the message.'
    }
  };

  if (form && submitBtn && submitText) {
    const originalContent = submitText.innerHTML;
    const lang = (form.getAttribute('data-lang') || 'es') as 'es' | 'en';
    const messages = toastMessages[lang];

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Deshabilitar botón y cambiar a estado de carga
      submitBtn.disabled = true;
      submitText.innerHTML = `
        ${submittingTexts[lang]}
        <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      `;

      try {
        const formData = new FormData(form);
        const res = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });

        const data = await res.json();

        if (res.ok) {
          (window as any).showToast(messages.success);
          form.reset();
        } else {
          let errMsg = messages.error;
          if (data.error === 'Todos los campos son obligatorios.') {
            errMsg = messages.errorFields;
          } else if (data.error === 'El formato del correo electrónico no es válido.') {
            errMsg = messages.errorEmail;
          } else if (data.error === 'Ocurrió un error inesperado al enviar el mensaje.') {
            errMsg = messages.errorUnexpected;
          } else if (data.error) {
            errMsg = data.error;
          }
          (window as any).showToast(errMsg);
        }
      } catch (err) {
        console.error(err);
        (window as any).showToast(messages.errorUnexpected);
      } finally {
        // Restaurar estado del botón
        submitBtn.disabled = false;
        submitText.innerHTML = originalContent;
      }
    });
  }
</script>
