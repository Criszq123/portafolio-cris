---
import Button from "@ui/Button.astro";
import { useTranslations } from "../../i18n/utils";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  id="hero"
  class="relative min-h-[90vh] flex items-center justify-center pt-24 pb-16 overflow-hidden"
>
  <div
    class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center"
  >
    <!-- Left Column: Text & CTAs -->
    <div
      class="lg:col-span-7 flex flex-col space-y-6 text-left animate-slide-up"
    >
      <!-- Status Badge -->
      <div
        class="inline-flex items-center self-start gap-2 rounded-full px-3 py-1 text-xs font-medium bg-brand-950/40 text-brand-300 border border-brand-800/30"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"
          ></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"
          ></span>
        </span>
        {t('hero.status')}
      </div>

      <!-- Headline -->
      <h1
        class="font-outfit text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-white leading-tight"
      >
        {t('hero.title')} <span
          class="bg-gradient-to-r from-brand-400 via-brand-500 to-rose-400 bg-clip-text text-transparent"
          >Cristofher</span
        >
        <br />
        <span class="text-dark-100">Junior Fullstack Developer</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-base sm:text-lg text-dark-300 max-w-2xl leading-relaxed">
        {t('hero.subtitle')}
      </p>

      <!-- Actions -->
      <div class="flex flex-wrap gap-4 pt-4">
        <Button href="#projects" variant="primary" size="lg" className="group">
          {t('hero.btnProjects')}
          <svg
            class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
        </Button>
        <Button href="#contact" variant="outline" size="lg">
          {t('hero.btnContact')}
        </Button>
      </div>
    </div>

    <!-- Right Column: Visual Mockup Card (Premium Front-end Vibe) -->
    <div
      class="lg:col-span-5 relative w-full flex justify-center animate-fade-in [animation-delay:200ms] z-10"
    >
      <!-- Glowing behind the card -->
      <div
        class="absolute -inset-1 rounded-2xl bg-gradient-to-tr from-brand-900 to-brand-500 opacity-20 blur-xl"
      >
      </div>

      <div
        class="relative w-full max-w-[450px] rounded-xl border border-dark-800 bg-dark-900/90 shadow-2xl backdrop-blur-xl overflow-hidden text-left font-mono text-xs text-dark-300"
      >
        <!-- Tab Bar -->
        <div
          class="flex items-center justify-between px-4 py-3 border-b border-dark-800 bg-dark-950/40"
        >
          <div class="flex gap-2">
            <div class="h-3 w-3 rounded-full bg-brand-600/80"></div>
            <div class="h-3 w-3 rounded-full bg-brand-500/80"></div>
            <div class="h-3 w-3 rounded-full bg-brand-400/80"></div>
          </div>
          <span class="text-[10px] text-dark-500">DeveloperProfile.ts</span>
          <div class="w-10"></div>
        </div>

        <!-- Code Content -->
        <div class="p-5 space-y-3 overflow-x-auto leading-relaxed">
          <div>
            <span class="text-brand-400">const</span>
            <span class="text-blue-400">developer</span> = &#123;
          </div>
          <div class="pl-4">
            <span class="text-dark-400">name:</span>
            <span class="text-emerald-400">'Cristofher'</span>,
          </div>
          <div class="pl-4">
            <span class="text-dark-400">role:</span>
            <span class="text-emerald-400">'Junior Fullstack Developer'</span>,
          </div>
          <div class="pl-4">
            <span class="text-dark-400">stack:</span> [
            <span class="text-emerald-400">'React.js'</span>,
            <span class="text-emerald-400">'Vue.js'</span>,
            <span class="text-emerald-400">'TypeScript'</span>,
            <span class="text-emerald-400">'Express.js'</span>,
            <span class="text-emerald-400">'C# (Razor)'</span>
            ],
          </div>
          <div class="pl-4">
            <span class="text-dark-400">transitionedFrom:</span>
            <span class="text-emerald-400">'QA Engineer'</span>,
          </div>
          <div class="pl-4">
            <span class="text-dark-400">lovesQuality:</span>
            <span class="text-amber-400">true</span>,
          </div>
          <div>&#125;;</div>

          <div
            class="pt-2 border-t border-dark-800/60 text-[10px] text-dark-500 flex items-center justify-between"
          >
            <span>{t('hero.cardLocation')}</span>
            <span class="text-brand-400/80">{t('hero.cardReady')}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
