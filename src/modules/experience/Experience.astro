---
import { getEntry } from "astro:content";
import ExperienceCard from "./ExperienceCard.astro";
import type { Experience } from "../../types/portfolio";
import { useTranslations } from "../../i18n/utils";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const experienceEntry = await getEntry("experience", `${lang}/list`);
const experiences = experienceEntry ? experienceEntry.data.experiences : [];
---

<section id="experience" class="py-24 relative overflow-hidden">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Header -->
    <div class="text-left mb-16 space-y-3">
      <span
        class="text-xs font-bold uppercase tracking-wider text-brand-400 font-mono"
      >
        {t('experience.badge')}
      </span>
      <h2 class="font-outfit text-3xl sm:text-4xl font-extrabold text-white">
        {t('experience.title')}
      </h2>
      <p class="text-sm sm:text-base text-dark-400 max-w-xl">
        {t('experience.subtitle')}
      </p>
    </div>

    <!-- Timeline container -->
    <div
      class="relative before:absolute before:left-[7px] before:top-2 before:bottom-2 before:w-[2px] before:bg-gradient-to-b before:from-brand-500 before:via-dark-800 before:to-transparent space-y-12"
    >
      {experiences.map((exp: Experience) => <ExperienceCard {...exp} />)}
    </div>
  </div>
</section>
