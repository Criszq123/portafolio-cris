---
import Badge from '@ui/Badge.astro';

interface Props {
  role: string;
  company: string;
  period: string;
  description: string;
  tags: string[];
}

const { role, company, period, description, tags } = Astro.props;
---

<div class="relative pl-8 sm:pl-10 group">
  <!-- Timeline Dot indicator -->
  <div class="absolute left-0 top-1.5 h-4 w-4 rounded-full border-2 border-brand-500 bg-dark-950 z-10 transition-transform group-hover:scale-125 duration-300">
    <div class="h-1.5 w-1.5 rounded-full bg-brand-500 m-auto absolute inset-0"></div>
  </div>
  
  <div class="flex flex-col space-y-3 rounded-xl border border-dark-800 bg-dark-900/40 p-6 backdrop-blur-sm transition-all duration-300 hover:border-brand-900/40 hover:bg-dark-900/60 hover:-translate-y-1 shadow-lg shadow-black/5 hover:shadow-brand-950/5">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
      <h3 class="font-outfit text-lg font-bold text-white group-hover:text-brand-300 transition-colors">
        {role}
      </h3>
      <span class="text-xs font-semibold text-brand-400 font-mono bg-brand-950/20 px-2 py-0.5 rounded border border-brand-900/20 self-start sm:self-center">
        {period}
      </span>
    </div>
    
    <div class="text-sm font-medium text-dark-300">
      {company}
    </div>
    
    <p class="text-sm text-dark-400 leading-relaxed font-sans">
      {description}
    </p>
    
    <div class="flex flex-wrap gap-2 pt-2">
      {tags.map((tag) => (
        <Badge variant="secondary">{tag}</Badge>
      ))}
    </div>
  </div>
</div>
